# Local development service URLs
# All values below are the defaults already built into vite.config.js.
# Uncomment and change any line to override a specific service URL.

# VITE_AUTH_SERVICE_URL=http://localhost:8081
# VITE_USER_SERVICE_URL=http://localhost:8083
# VITE_ORG_SERVICE_URL=http://localhost:8084
# VITE_CONTEST_SERVICE_URL=http://localhost:8085
# VITE_EXECUTION_SERVICE_URL=http://localhost:8086
# VITE_LEADERBOARD_SERVICE_URL=http://localhost:8087
# VITE_PAYMENT_SERVICE_URL=http://localhost:8088
# VITE_NOTIFICATION_SERVICE_URL=http://localhost:8091

# Uncomment the line below ONLY if you want all traffic to go through the
# nginx API gateway instead of hitting each service directly.
# VITE_API_GATEWAY_URL=http://localhost:8080
